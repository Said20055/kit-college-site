# Продакшен-окружение для docker-compose.prod.yml.
# Скопируйте в .env на сервере и подставьте реальные значения (надёжные пароли!).
# Файл .env в репозиторий НЕ коммитится.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=kit
POSTGRES_PASSWORD=замените-на-надёжный-пароль
POSTGRES_DB=kit

# Подключение из контейнеров (web/migrate) — хост = имя сервиса compose.
DATABASE_URL=postgresql://kit:замените-на-надёжный-пароль@db:5432/kit?schema=public

# Подключение во время СБОРКИ web (пререндер), build выполняется в host-сети —
# хост = опубликованный порт БД на 127.0.0.1. Логин/пароль/БД те же.
BUILD_DATABASE_URL=postgresql://kit:замените-на-надёжный-пароль@127.0.0.1:5432/kit?schema=public

# ── Первый администратор CMS (используется только при первичном сидировании) ──
ADMIN_EMAIL=admin@kit-college.ru
ADMIN_PASSWORD=замените-на-надёжный-пароль

# ── Резервное копирование (scripts/backup.sh) ─────────────────────────────────
# Имя тома загрузок = <имя_проекта>_kit-uploads. Имя проекта по умолчанию —
# имя каталога; при необходимости задайте COMPOSE_PROJECT_NAME.
# UPLOADS_VOLUME=kit-college_kit-uploads
# BACKUP_DIR=./backups
# RETENTION_DAYS=14
