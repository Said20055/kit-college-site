# Подключение к PostgreSQL (РФ-хостинг / локальный Docker).
# Скопируйте в .env и подставьте реальные значения.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# Первый администратор CMS (создаётся скриптом сидирования).
ADMIN_EMAIL="admin@example.ru"
ADMIN_PASSWORD="задайте-надёжный-пароль"

# Каталог для загруженных медиафайлов (вне webroot). В проде — примонтированный том.
MEDIA_DIR="./var/uploads"
